# Claude Code Hooks Configuration
# Copy to config.env and customize. Generated by setup.sh.

# ─── ntfy.sh Mobile Notifications ───
NTFY_TOPIC="claude-CHANGEME"
NTFY_TOKEN=""
NTFY_URL="https://ntfy.sh"

# ─── Logging ───
HOOKS_LOG_MAX_BYTES=10485760  # 10MB per log file

# ─── Failed Paths ───
HOOKS_FAILED_PATHS_TTL_DAYS=7
HOOKS_FAILED_PATHS_MAX_INJECT=20

# ─── Permission Auto-Approval ───
# Auto-approve Read, Glob, Grep, WebSearch, WebFetch and safe Bash commands
HOOKS_AUTO_APPROVE_READONLY=true

# ─── TTS Notifications ───
HOOK_TTS_ENABLED=false
HOOK_TTS_MIN_SEVERITY=block      # info, warn, block, escalation
HOOK_TTS_PROVIDER=say            # say, openai, elevenlabs

# ─── TTS API Keys (only needed if using openai or elevenlabs provider) ───
# OPENAI_TTS_API_KEY=""
# ELEVENLABS_API_KEY=""

# ─── Context Backup Thresholds (used by StatusLine) ───
HOOKS_BACKUP_FIRST_THRESHOLD=50  # percent of context window
HOOKS_BACKUP_INTERVAL=15         # subsequent backups every N%
HOOKS_BACKUP_MAX_KEPT=5          # max backup files retained

# ─── Format/Typecheck Timeouts (seconds) ───
HOOKS_FORMAT_TIMEOUT=10
HOOKS_TYPECHECK_TIMEOUT=15

# ─── Test Gate Timeout (seconds) ───
HOOKS_TEST_TIMEOUT=60
